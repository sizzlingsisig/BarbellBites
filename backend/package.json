{
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemon": "^3.1.13",
    "zod": "^4.3.6"
  },
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/resetAndSeed.ts",
    "db:sync": "tsx src/scripts/syncClusters.ts",
    "db:sync:p2s": "tsx src/scripts/syncClusters.ts --from=primary --to=secondary --mode=replace",
    "db:sync:s2p": "tsx src/scripts/syncClusters.ts --from=secondary --to=primary --mode=replace",
    "job:sync": "tsx src/jobs/syncWorker.ts",
    "job:sync:once": "tsx src/scripts/syncClusters.ts --from=primary --to=secondary --mode=upsert",
    "bru:v1:smoke": "cd BarbellBites && bru run V1/Smoke -r --env Development --bail --noproxy",
    "bru:v1:edge": "cd BarbellBites && bru run V1/Edge -r --env Development --bail --noproxy",
    "bru:v2:smoke": "cd BarbellBites && bru run V2/Smoke -r --env Development --bail --noproxy",
    "bru:v2:edge": "cd BarbellBites && bru run V2/Edge -r --env Development --bail --noproxy",
    "test:v1:smoke": "tsx src/scripts/runBrunoSuite.ts --suite=V1/Smoke",
    "test:v1:edge": "tsx src/scripts/runBrunoSuite.ts --suite=V1/Edge",
    "test:v2:smoke": "tsx src/scripts/runBrunoSuite.ts --suite=V2/Smoke",
    "test:v2:edge": "tsx src/scripts/runBrunoSuite.ts --suite=V2/Edge",
    "test:smoke": "npm run test:v1:smoke && npm run test:v2:smoke",
    "test:edge": "npm run test:v1:edge && npm run test:v2:edge",
    "test:all": "npm run test:smoke && npm run test:edge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@usebruno/cli": "^3.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
