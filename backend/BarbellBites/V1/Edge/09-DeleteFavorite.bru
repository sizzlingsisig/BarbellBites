meta {
  name: Edge Delete Favorite
  type: http
  seq: 9
}

delete {
  url: {{V1_API_LINK}}/favorites/{{edgeRecipeId}}
  auth: bearer
}

auth:bearer {
  token: {{edgeOwnerToken}}
}

script:post-response {
  const status = res.getStatus();
  if (status !== 204) {
    throw new Error(`Expected 204, got ${status}`);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
